// ═══════════════════════════════════════════════════════════════
// ALERT — ganti bagian alert yang existing dengan ini
// ═══════════════════════════════════════════════════════════════

if barstate.isnew and session_filter and array.size(forex_names) >= 5 and array.size(metals_names) >= 2 and array.size(crypto_names) >= 2

    // Forex Top 5 (untuk Telegram)
    f1 = array.get(forex_names, 0) + " | " + str.tostring(array.get(forex_changes, 0), "#.##") + "% | " + (array.get(forex_changes, 0) > 0 ? "LONG" : "SHORT")
    f2 = array.get(forex_names, 1) + " | " + str.tostring(array.get(forex_changes, 1), "#.##") + "% | " + (array.get(forex_changes, 1) > 0 ? "LONG" : "SHORT")
    f3 = array.get(forex_names, 2) + " | " + str.tostring(array.get(forex_changes, 2), "#.##") + "% | " + (array.get(forex_changes, 2) > 0 ? "LONG" : "SHORT")
    f4 = array.get(forex_names, 3) + " | " + str.tostring(array.get(forex_changes, 3), "#.##") + "% | " + (array.get(forex_changes, 3) > 0 ? "LONG" : "SHORT")
    f5 = array.get(forex_names, 4) + " | " + str.tostring(array.get(forex_changes, 4), "#.##") + "% | " + (array.get(forex_changes, 4) > 0 ? "LONG" : "SHORT")

    // Metals
    m1 = array.get(metals_names, 0) + " | " + str.tostring(array.get(metals_changes, 0), "#.##") + "% | " + (array.get(metals_changes, 0) > 0 ? "LONG" : "SHORT")
    m2 = array.get(metals_names, 1) + " | " + str.tostring(array.get(metals_changes, 1), "#.##") + "% | " + (array.get(metals_changes, 1) > 0 ? "LONG" : "SHORT")

    // Crypto
    c1 = array.get(crypto_names, 0) + " | " + str.tostring(array.get(crypto_changes, 0), "#.##") + "% | " + (array.get(crypto_changes, 0) > 0 ? "LONG" : "SHORT")
    c2 = array.get(crypto_names, 1) + " | " + str.tostring(array.get(crypto_changes, 1), "#.##") + "% | " + (array.get(crypto_changes, 1) > 0 ? "LONG" : "SHORT")

    // ── Alert 1: Telegram — top 5 saja, tidak berubah ──
    msg = timestamp_str   + 
     "\\n\\n"          +
     "FOREX\\n"        +
     f1 + "\\n"        + 
     f2 + "\\n"        + 
     f3 + "\\n"        +
     f4 + "\\n"        + 
     f5 + "\\n\\n"     +
     "METALS\\n"       +
     m1 + "\\n"        + 
     m2 + "\\n\\n"     +
     "CRYPTO\\n"       +
     c1 + "\\n"        + 
     c2 + "\\n\\n"     +
     "MARKET CONTEXT\\n"    +
     "US10Y: "  + str.tostring(us10y_chg,  "#.##") + "%\\n" +
     "DXY: "    + str.tostring(dxy_chg,    "#.##") + "%\\n" +
     "AUDNZD: " + str.tostring(audnzd_chg, "#.##") + "%\\n" +
     "CHFJPY: " + str.tostring(chfjpy_chg, "#.##") + "%\\n" +
     "EURGBP: " + str.tostring(eurgbp_chg, "#.##") + "%\\n" +
     "USDCAD: " + str.tostring(usdcad_chg, "#.##") + "%\\n" +
     "XAUXAG: " + str.tostring(xauxag_chg, "#.##") + "%"

    alert("{\"chat_id\": \"" + chat_id + "\", \"text\": \"" + msg + "\"}", alert.freq_once_per_bar)

    // ── Alert 2: Dashboard — semua 24 pair ──
    // Build forex array string (semua pair, sorted by abs change)
    forex_json = ""
    forex_sz = array.size(forex_names)
    for i = 0 to forex_sz - 1
        pair_name = array.get(forex_names, i)
        pair_chg  = array.get(forex_changes, i)
        pair_dir  = pair_chg > 0 ? "LONG" : "SHORT"
        comma = i < forex_sz - 1 ? "," : ""
        forex_json := forex_json + "{\"pair\":\"" + pair_name + "\",\"pct\":" + str.tostring(pair_chg, "#.##") + ",\"dir\":\"" + pair_dir + "\"}" + comma

    json = "{" +
     "\"time\":\"" + timestamp_str + "\"," +
     "\"mode\":\"" + mode + "\"," +
     "\"forex\":[" + forex_json + "]," +
     "\"metals\":[" +
       "{\"pair\":\"" + array.get(metals_names,0) + "\",\"pct\":" + str.tostring(array.get(metals_changes,0),"#.##") + ",\"dir\":\"" + (array.get(metals_changes,0) > 0 ? "LONG" : "SHORT") + "\"}," +
       "{\"pair\":\"" + array.get(metals_names,1) + "\",\"pct\":" + str.tostring(array.get(metals_changes,1),"#.##") + ",\"dir\":\"" + (array.get(metals_changes,1) > 0 ? "LONG" : "SHORT") + "\"}" +
     "]," +
     "\"crypto\":[" +
       "{\"pair\":\"" + array.get(crypto_names,0) + "\",\"pct\":" + str.tostring(array.get(crypto_changes,0),"#.##") + ",\"dir\":\"" + (array.get(crypto_changes,0) > 0 ? "LONG" : "SHORT") + "\"}," +
       "{\"pair\":\"" + array.get(crypto_names,1) + "\",\"pct\":" + str.tostring(array.get(crypto_changes,1),"#.##") + ",\"dir\":\"" + (array.get(crypto_changes,1) > 0 ? "LONG" : "SHORT") + "\"}" +
     "]," +
     "\"context\":{" +
       "\"US10Y\":" + str.tostring(us10y_chg,"#.##") + "," +
       "\"DXY\":"   + str.tostring(dxy_chg,  "#.##") + "," +
       "\"AUDNZD\":" + str.tostring(audnzd_chg,"#.##") + "," +
       "\"CHFJPY\":" + str.tostring(chfjpy_chg,"#.##") + "," +
       "\"EURGBP\":" + str.tostring(eurgbp_chg,"#.##") + "," +
       "\"USDCAD\":" + str.tostring(usdcad_chg,"#.##") + "," +
       "\"XAUXAG\":" + str.tostring(xauxag_chg,"#.##") +
     "}}"

    alert(json, alert.freq_once_per_bar)
